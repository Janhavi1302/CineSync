{
  "name": "cinesync-ai",
  "version": "1.0.0",
  "type": "module",
  "description": "AI-native real-time cinematic dubbing and debugging platform",
  "main": "./out/main/index.js",
  "author": "CineSync Team",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:win": "electron-vite build && electron-builder --win --config",
    "build:installer": "electron-vite build && electron-builder --win nsis --config",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.cinesync.ai",
    "productName": "CineSync AI",
    "copyright": "Copyright © 2026 CineSync",
    "directories": {
      "output": "dist-installer"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "ai-engine/dist/cinesync-ai-engine",
        "to": "ai-engine/cinesync-ai-engine",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "ai-engine",
        "to": "ai-engine",
        "filter": [
          "main.py",
          "config.py",
          "modal_app.py",
          "core/**/*",
          "services/**/*",
          "!**/__pycache__/**",
          "!*.pyc",
          "!.env",
          "!build/**",
          "!dist/**",
          "!*.spec"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "CineSync-AI-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CineSync AI",
      "license": "LICENSE.md"
    }
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "vite": "^5.4.0"
  }
}
